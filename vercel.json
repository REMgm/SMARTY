{
  "version": 2,
  "name": "smarty-architecture",
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.md", "use": "@vercel/static" },
    { "src": "**/*.txt", "use": "@vercel/static" },
    { "src": "**/*.svg", "use": "@vercel/static" },
    { "src": "**/*.jpg", "use": "@vercel/static" },
    { "src": "**/*.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/arch", "dest": "/architecture.html" },
    { "src": "/pins", "dest": "/memory/pins.md" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
