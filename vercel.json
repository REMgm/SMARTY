{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/arch", "destination": "/architecture.html" },
    { "source": "/pins", "destination": "/memory/pins.md" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
